# Azure Storage Account Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_STORAGE_FILE_SHARE_NAME=your_file_share_name

# Alternative: Use Connection String instead of account name/key
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Optional: Root folder to start browsing from (relative to file share root)
# Leave empty or comment out to start from the file share root
# Examples: "documents", "shared/projects", "users/john"
# ROOT_FOLDER=documents/public

# Server Configuration
PORT=3000
NODE_ENV=production

# Authentication is handled by Azure App Service Authentication/Authorization

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100